  "description": "API Restful - Alpha Tower Sales System",
  "main": "index.ts",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --inspect --transpile-only --ignore-watch node_modules src/shared/http/server.ts",
    "database": "ts-node-dev ./node_modules/typeorm/cli.js",
    "migrations:run": "ts-node ./node_modules/typeorm/cli.js migration:run",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .ts",
    "lint-fix": "eslint . --ext .ts --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fernandobritto/Alpha-Tower.git"
  },
  "keywords": [
    "NodeJS",
    "TypeORM",
    "Typescript",
    "APIRestful"
  ],
  "author": "Fernando Britto",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fernandobritto/Alpha-Tower/issues"
  },
  "homepage": "https://github.com/fernandobritto/Alpha-Tower#readme",
  "dependencies": {
    "bcryptjs": "2.4.3",
    "celebrate": "13.0.4",
    "cors": "2.8.5",
    "date-fns": "2.18.0",
    "express": "4.17.1",
    "express-async-errors": "3.1.1",
    "jsonwebtoken": "8.5.1",
    "multer": "1.4.2",
    "pg": "8.5.1",
    "reflect-metadata": "0.1.13",
    "typeorm": "0.2.31"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.2",
    "@types/cors": "2.8.10",
    "@types/express": "4.17.11",
    "@types/joi": "17.2.3",
    "@types/jsonwebtoken": "8.5.0",
    "@types/multer": "1.4.5",
    "@types/node": "14.14.27",
    "@typescript-eslint/eslint-plugin": "4.15.0",
    "@typescript-eslint/parser": "4.15.0",
    "eslint": "7.20.0",
    "eslint-config-prettier": "7.2.0",
    "eslint-config-standard": "16.0.2",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "3.3.1",
    "eslint-plugin-promise": "4.3.1",
    "prettier": "2.2.1",
    "ts-node-dev": "1.1.1",
